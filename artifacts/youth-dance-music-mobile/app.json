{
  "expo": {
    "name": "Youth Dance Music",
    "slug": "youth-dance-music-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "youthdancemusic",
      "youth-dance-music-mobile"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1973E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.youthdancemusic.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Youth Dance Music uses the camera to scan dance QR codes so you can quickly request a song."
      }
    },
    "android": {
      "package": "com.youthdancemusic.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Youth Dance Music uses the camera to scan dance QR codes so you can quickly request a song."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "6a9dd245-610e-4999-8098-58289c4261b4"
      }
    },
    "owner": "mattk311"
  }
}
