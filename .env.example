# Google AdSense Configuration
# Get these values from your Google AdSense account: https://adsense.google.com
# After approval, add your publisher ID and ad unit slot IDs here

# Your AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_CLIENT=

# Ad Unit Slot IDs (create these in your AdSense account)
VITE_ADSENSE_SLOT_BANNER=     # Top banner ad (728x90 or responsive)
VITE_ADSENSE_SLOT_RECTANGLE=  # In-content rectangle ad (300x250 or responsive)
VITE_ADSENSE_SLOT_FOOTER=     # Footer banner ad (728x90 or responsive)

# Note: These are optional - ads won't show until you add your AdSense credentials
# The app will work fine without ads while you're waiting for AdSense approval
